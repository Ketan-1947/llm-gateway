# --- Provider keys (SECRET — never commit the real .env) ---
ANTHROPIC_API_KEY=sk-ant-...
# Optional: only needed once routing sends traffic to OpenAI models.
OPENAI_API_KEY=sk-...

# --- Server ---
PORT=3000
HOST=0.0.0.0

# --- Gateway auth ---
# Comma-separated plaintext client keys (dev). Empty AND no hashes => auth off.
GATEWAY_API_KEYS=dev-key-123
# Production: comma-separated sha256 hex hashes of accepted keys (raw never stored).
#   printf '%s' "your-key" | sha256sum
GATEWAY_API_KEY_HASHES=

# --- Hardening (Phase 5). 0 disables a given limit. ---
RATE_LIMIT_PER_MIN=60
DAILY_BUDGET_USD=0
MAX_REQUEST_COST_USD=0
MAX_PROMPT_TOKENS=150000
JAILBREAK_BLOCK=true
PII_MODE=flag           # flag | block

# --- Defaults ---
DEFAULT_MODEL=claude-haiku-4-5
DEFAULT_MAX_TOKENS=1024
DEFAULT_TEMPERATURE=0.7

# --- Observability (Phase 4) ---
# Model used as the "naive baseline" for the savings comparison in /v1/usage.
BASELINE_MODEL=claude-sonnet-4-6
# Optional append-only JSONL log file. Empty = in-memory only.
USAGE_LOG_FILE=
